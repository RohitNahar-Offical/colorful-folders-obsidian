{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ESNext",
    "allowJs": true,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": false,
    "lib": [
      "DOM",
      "ESNext"
    ],
    "types": [
      "node",
      "obsidian"
    ],
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "**/*.ts"
  ]
}
